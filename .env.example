# Agit OAuth User Access Token (그룹별 토큰 fallback / 전역 검색용)
# 그룹별 전용 토큰(아래 AGIT_TOKEN_*)이 비어 있을 때 자동으로 이 값으로 fallback.
# 단일 토큰만 가진 환경에서도 그대로 동작합니다.
AGIT_TOKEN=eyJraWQ...

# ─── 그룹별 전용 OAuth 토큰 (정확도 향상 + 권한 분리 목적) ──────────
# 발급 후 채우면 해당 그룹은 이 토큰으로만 호출됩니다.
# 비어 있으면 위 AGIT_TOKEN으로 fallback.
AGIT_TOKEN_ELEC=        # 전자결재 그룹 전용 토큰
AGIT_TOKEN_HR=          # 인사 시스템 그룹 전용 토큰

# 본인의 Agit user ID (target_id 파라미터에 사용)
AGIT_USER_ID=300081298

# 회사 GCP에서 발급된 Gemini API key
# - AI Studio: https://aistudio.google.com/app/apikey
# - GCP Console: APIs & Services → Credentials → API Keys
#   ※ "Generative Language API" 활성화 필요
GEMINI_API_KEY=AIza...

# 사용할 Gemini 모델 (선택, 기본 gemini-2.0-flash)
# 옵션: gemini-2.0-flash (균형/저비용), gemini-2.5-flash (최신), gemini-2.5-pro (최고 품질)
GEMINI_MODEL=gemini-2.0-flash
